{
  "info": {
    "name": "hash-generator API",
    "description": "Generate cryptographic hashes (MD5, SHA, HMAC) and secure random keys",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://hash-generator-delta.vercel.app",
      "type": "string"
    },
    {
      "key": "api_key",
      "value": "free-demo-key",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-API-Key",
            "value": "{{api_key}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "health"
          ]
        }
      }
    },
    {
      "name": "List Algorithms",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-API-Key",
            "value": "{{api_key}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/algorithms",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "algorithms"
          ]
        }
      }
    },
    {
      "name": "Hash Text",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-API-Key",
            "value": "{{api_key}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/hash",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "hash"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"\",\n  \"algorithms\": \"\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      }
    },
    {
      "name": "Hmac Hash",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-API-Key",
            "value": "{{api_key}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/hmac",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "hmac"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"\",\n  \"key\": \"\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      }
    },
    {
      "name": "Check Password",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-API-Key",
            "value": "{{api_key}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/password/check",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "password",
            "check"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"password\": \"\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      }
    },
    {
      "name": "Generate Random Key",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-API-Key",
            "value": "{{api_key}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/random/key",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "random",
            "key"
          ]
        }
      }
    }
  ]
}